{
  "name": "projects",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:turbo": "bash ./scripts/dev-turbo.sh",
    "dev:monitor": "node scripts/dev-monitor.js",
    "dev:auto": "node scripts/dev-monitor.js &",
    "dev:clean": "bash ./scripts/clean-cache.sh && bash ./scripts/dev.sh",
    "dev:hard": "rm -rf .next node_modules && pnpm install && bash ./scripts/dev.sh",
    "build": "bash ./scripts/build.sh",
    "build:turbo": "next build --turbo",
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint",
    "start": "bash ./scripts/start.sh",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "start:dev-schema": "COZE_PROJECT_ENV=DEV pm2 start ecosystem.config.cjs",
    "start:prod-schema": "COZE_PROJECT_ENV=PROD pm2 start ecosystem.config.cjs --env production",
    "stop:prod": "pm2 stop ecosystem.config.cjs",
    "restart:prod": "pm2 restart ecosystem.config.cjs",
    "status:prod": "pm2 status",
    "logs:prod": "pm2 logs ai-venture",
    "db:init": "bash ./scripts/init-db.sh",
    "db:migrate": "bash ./scripts/migrate.sh",
    "ts-check": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "bash ./scripts/clean-cache.sh",
    "health": "curl -s http://localhost:5000/api/health | head -50",
    "monitor": "tail -f /app/work/logs/bypass/monitor.log",
    "sql": "node sql.js"
  },
