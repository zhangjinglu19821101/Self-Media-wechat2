[project]
requires = [ "nodejs-24" ]
template = "nextjs"
version = "legacy"
appliedPatches = [
  "nextjs/next-output-tracing-root@0.0.13",
  "nextjs/replace-npx-with-pnpm@0.0.13"
]

[dev]
build = ["bash", "-c", "cd /workspace/projects && pnpm install"]
run = ["bash", "-c", "cd /workspace/projects && pnpm next dev --port 5000 -H 0.0.0.0"]

[deploy]
build = [ "bash", "./scripts/build.sh" ]
run = [ "bash", "./scripts/start.sh" ]
deps = [ "git" ]
