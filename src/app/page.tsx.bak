const EMOTION_OPTIONS = [
  { 
    value: 'rational', 
    label: '理性客观', 
    desc: '冷静分析、数据支撑、客观呈现',
    icon: Target,
    color: 'from-sky-500 to-cyan-500',
    bg: 'bg-sky-50',
    border: 'border-sky-200',
    text: 'text-sky-700'
  },
  { 
    value: 'caution', 
    label: '踩坑警醒', 
    desc: '风险警示、避坑指南、警示教育',
    icon: Shield,
    color: 'from-orange-500 to-amber-500',
    bg: 'bg-orange-50',
    border: 'border-orange-200',
    text: 'text-orange-700'
  },
  { 
    value: 'empathy', 
    label: '温情共情', 
    desc: '情感共鸣、人文关怀、温暖叙事',
    icon: MessageSquare,
    color: 'from-pink-500 to-rose-500',
    bg: 'bg-pink-50',
    border: 'border-pink-200',
    text: 'text-pink-700'
  },
  { 
    value: 'authority', 
    label: '专业权威', 
    desc: '专家视角、深度解读、权威背书',
    icon: Zap,
    color: 'from-violet-500 to-purple-500',
    bg: 'bg-violet-50',
    border: 'border-violet-200',
    text: 'text-violet-700'
  },
];

// 标签颜色映射
function getTagColor(tag: string): string {
  const tagLower = tag.toLowerCase();
  if (tagLower.includes('港险') || tagLower.includes('重疾')) return 'bg-purple-100 text-purple-700';
  if (tagLower.includes('医疗') || tagLower.includes('报销')) return 'bg-blue-100 text-blue-700';
  if (tagLower.includes('意外') || tagLower.includes('理赔')) return 'bg-orange-100 text-orange-700';
  if (tagLower.includes('踩坑') || tagLower.includes('警告')) return 'bg-red-100 text-red-700';
  if (tagLower.includes('省钱') || tagLower.includes('划算')) return 'bg-green-100 text-green-700';
  return 'bg-gray-100 text-gray-700';
}

// 素材类型图标
function getMaterialTypeIcon(type: string) {
  switch (type) {
    case 'case': return '📋';
    case 'data': return '📊';
    case 'story': return '📖';
    case 'quote': return '💬';
    case 'opening': return '🎬';
    case 'ending': return '🎬';
    default: return '📄';
  }
}

// 系统功能卡片
const SYSTEM_FEATURES = [
  {
    icon: Bot,
    title: '多Agent协作',
    description: '战略决策者、技术官、内容创作者等智能协同',
    color: 'from-sky-500 to-cyan-500'
  },
  {
    icon: Brain,
    title: '智能决策',
    description: 'AI自主拆解任务、合规校验、用户确认',
    color: 'from-violet-500 to-purple-500'
  },
  {
    icon: Workflow,
    title: '全流程自动化',
    description: '从创作到发布的完整工作流',
    color: 'from-emerald-500 to-teal-500'
  },
  {
    icon: Database,
    title: '素材库支持',
    description: '智能素材推荐和管理',
    color: 'from-amber-500 to-orange-500'
  }
];

export default function HomePage() {
  // 创作引导状态
  const [mainInstruction, setMainInstruction] = useState('');
  const [coreOpinion, setCoreOpinion] = useState('');
  const [emotionTone, setEmotionTone] = useState('rational');
  const [selectedMaterialIds, setSelectedMaterialIds] = useState<string[]>([]);
  
  // AI 建议
  const [suggestedOpinions, setSuggestedOpinions] = useState<string[]>([]);
  const [loadingSuggestions, setLoadingSuggestions] = useState(false);
  const [recommendedMaterials, setRecommendedMaterials] = useState<MaterialItem[]>([]);
  const [loadingMaterials, setLoadingMaterials] = useState(false);
  
  // 素材库
  const [materials, setMaterials] = useState<MaterialItem[]>([]);
  const [loadingMaterialsList, setLoadingMaterialsList] = useState(false);
  const [materialFilter, setMaterialFilter] = useState('all');
  const [materialSearch, setMaterialSearch] = useState('');
  
  // 提交状态
  const [submitting, setSubmitting] = useState(false);
  const [activeTab, setActiveTab] = useState('create');

  // 加载素材库列表
  const loadMaterialsList = useCallback(async () => {
    setLoadingMaterialsList(true);
    try {
      const response = await fetch('/api/materials?limit=50');
      const data = await response.json();
      if (data.success) {
        setMaterials(data.data.items || []);
      }
    } catch (error) {
      console.error('加载素材库失败:', error);
    } finally {
      setLoadingMaterialsList(false);
    }
  }, []);

  // 初始化
  useEffect(() => {
    loadMaterialsList();
    
    // 加载本地草稿
    const draft = loadDraft();
    if (draft) {
      setCoreOpinion(draft.coreOpinion);
      setEmotionTone(draft.emotionTone);
      setSelectedMaterialIds(draft.selectedMaterialIds);
    }
  }, [loadMaterialsList]);

  // 自动保存
  useEffect(() => {
    if (mainInstruction || coreOpinion || emotionTone !== 'rational' || selectedMaterialIds.length > 0) {
      saveDraft({ coreOpinion, emotionTone, selectedMaterialIds });
    }
  }, [mainInstruction, coreOpinion, emotionTone, selectedMaterialIds]);

  // 🔥 AI 生成建议观点
  const handleSuggestOpinions = async () => {
    if (!mainInstruction.trim()) {
      toast.error('请先输入创作主题');
      return;
    }
    
    setLoadingSuggestions(true);
    try {
      const response = await fetch('/api/agents/b/suggest-opinion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ instruction: mainInstruction }),
      });
      const data = await response.json();
      if (data.success && data.suggestions) {
        setSuggestedOpinions(data.suggestions);
        toast.success('已生成3个建议观点！');
      } else {
        toast.error(data.error || '生成建议失败');
      }
    } catch (error) {
      toast.error('生成建议失败');
    } finally {
      setLoadingSuggestions(false);
    }
  };

  // 🔥 AI 推荐素材
  const handleMaterialRecommend = async () => {
    if (!mainInstruction.trim()) {
      toast.error('请先输入创作主题');
      return;
    }
    
    setLoadingMaterials(true);
    try {
      const response = await fetch(`/api/materials/recommend?instruction=${encodeURIComponent(mainInstruction)}&limit=6`);
      const data = await response.json();
      if (data.success) {
        setRecommendedMaterials(data.data || []);
        toast.success('已为您推荐相关素材！');
      }
    } catch (error) {
      console.error('推荐素材失败:', error);
    } finally {
      setLoadingMaterials(false);
    }
  };

  // 选择建议观点
  const handleSelectOpinion = (opinion: string) => {
    setCoreOpinion(opinion);
    setSuggestedOpinions([]);
  };

  // 切换素材选中
  const toggleMaterial = (materialId: string) => {
    setSelectedMaterialIds(prev => 
      prev.includes(materialId)
        ? prev.filter(id => id !== materialId)
        : [...prev, materialId]
    );
  };

  // 筛选素材
  const filteredMaterials = materials.filter(m => {
    const matchFilter = materialFilter === 'all' || m.type === materialFilter;
    const matchSearch = !materialSearch || 
      m.title.toLowerCase().includes(materialSearch.toLowerCase()) ||
      m.content.toLowerCase().includes(materialSearch.toLowerCase());
    return matchFilter && matchSearch;
  });

  // 计算完成度
  const calculateCompletion = () => {
    let score = 0;
    if (mainInstruction.trim()) score += 40;
    if (coreOpinion.trim()) score += 25;
    if (emotionTone !== 'rational') score += 15;
    if (selectedMaterialIds.length > 0) score += 20;
    return Math.min(score, 100);
  };

  // 提交创作
  const handleSubmit = async () => {
    if (!mainInstruction.trim()) {
      toast.error('请输入创作主题');
      return;
    }

    setSubmitting(true);
    try {
      // 组装 userOpinion
      const userOpinion = coreOpinion || mainInstruction;

      const response = await fetch('/api/commands', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userOpinion,
          emotionTone,
          materialIds: selectedMaterialIds,
        }),
      });

      const data = await response.json();
      if (data.success) {
        toast.success('创作任务已提交！正在启动多Agent协作...');
        
        // 清理本地草稿
        localStorage.removeItem(getStorageKey());
        
        // 跳转到任务管理页面
        setTimeout(() => {
          window.location.href = '/full-home';
        }, 1500);
      } else {
        toast.error(data.error || '提交失败');
      }
    } catch (error) {
      toast.error('提交失败');
    } finally {
      setSubmitting(false);
    }
  };

  const completion = calculateCompletion();
  const selectedTone = EMOTION_OPTIONS.find(t => t.value === emotionTone)!;

  return (
    <div className="min-h-screen bg-slate-50">
      {/* 顶部导航栏 */}
      <header className="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex items-center justify-between h-16">
            {/* Logo */}
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 bg-gradient-to-br from-sky-500 to-cyan-500 rounded-xl flex items-center justify-center">
                <Sparkles className="w-6 h-6 text-white" />
              </div>
              <div>
                <h1 className="text-xl font-bold bg-gradient-to-r from-sky-600 to-cyan-600 bg-clip-text text-transparent">
                  Agent 创作平台
                </h1>
                <p className="text-xs text-slate-500">智能多Agent协作系统</p>
              </div>
            </div>

            {/* 快捷导航 */}
            <div className="flex items-center gap-2">
              <Link href="/full-home">
                <Button variant="outline" size="sm" className="h-9 gap-1.5">
                  <ListTodo className="w-4 h-4" />
                  <span className="hidden sm:inline">任务列表</span>
                </Button>
              </Link>
              <Link href="/materials">
                <Button variant="outline" size="sm" className="h-9 gap-1.5">
                  <Database className="w-4 h-4" />
                  <span className="hidden sm:inline">素材库</span>
                </Button>
              </Link>
            </div>
          </div>
        </div>
      </header>

      {/* 主内容区 */}
      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {/* 左侧：创作引导区域 */}
          <div className="lg:col-span-2 space-y-6">
            {/* 页面标题 */}
            <div className="space-y-2">
              <h2 className="text-2xl font-bold text-slate-900 flex items-center gap-3">
                <Sparkles className="w-7 h-7 text-sky-500" />
                开始创作
              </h2>
              <p className="text-slate-600">
                通过多Agent智能协作，从创作到发布的完整工作流
              </p>
            </div>

            <Tabs value={activeTab} onValueChange={setActiveTab} className="space-y-6">
              <TabsList className="grid w-full grid-cols-2 bg-slate-100 p-1 rounded-xl">
                <TabsTrigger value="create" className="rounded-lg data-[state=active]:bg-white data-[state=active]:shadow-sm">
                  <BookOpen className="w-4 h-4 mr-2" />
                  创作引导
                </TabsTrigger>
                <TabsTrigger value="overview" className="rounded-lg data-[state=active]:bg-white data-[state=active]:shadow-sm">
                  <Layers className="w-4 h-4 mr-2" />
                  系统概览
                </TabsTrigger>
              </TabsList>

              {/* 创作引导标签页 */}
              <TabsContent value="create" className="space-y-6">
                {/* 创作主题 - 主要输入 */}
                <Card className="border-2 border-slate-200 shadow-sm hover:shadow-md transition-all duration-300">
                  <CardHeader className="pb-3">
                    <CardTitle className="text-lg flex items-center gap-2">
                      <div className="w-8 h-8 bg-gradient-to-br from-sky-500 to-cyan-500 rounded-lg flex items-center justify-center">
                        <Target className="w-4 h-4 text-white" />
                      </div>
                      创作主题
                      <span className="ml-auto">
                        <Badge variant="secondary" className="text-xs bg-red-50 text-red-600 hover:bg-red-50">
                          必填
                        </Badge>
                      </span>
                    </CardTitle>
                    <CardDescription>
                      告诉 AI 你想要创作什么内容，越详细越好
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <Textarea
                      placeholder="例如：写一篇关于香港保险和内地保险对比的文章，目标是帮助读者了解两者的优缺点。从保障范围、理赔流程、投资收益等多个维度进行深入分析..."
                      value={mainInstruction}
                      onChange={(e) => setMainInstruction(e.target.value)}
                      rows={5}
                      className="resize-none text-base leading-relaxed border-slate-200 focus:border-sky-500 focus:ring-sky-500/20"
                    />
                  </CardContent>
                </Card>

                {/* 核心观点 + 情感基调 + 素材关联 */}
                <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                  {/* 核心观点 */}
                  <Card className="md:col-span-2 border border-slate-200 shadow-sm">
                    <CardHeader className="pb-3">
                      <div className="flex items-center justify-between">
                        <CardTitle className="text-base flex items-center gap-2">
                          <BookOpen className="w-4 h-4 text-sky-500" />
                          核心观点
                        </CardTitle>
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={handleSuggestOpinions}
                          disabled={!mainInstruction.trim() || loadingSuggestions}
                          className="h-8 gap-1 text-sky-600 hover:text-sky-700 hover:bg-sky-50"
                        >
                          {loadingSuggestions ? (
                            <Loader2 className="w-3.5 h-3.5 animate-spin" />
                          ) : (
                            <Sparkles className="w-3.5 h-3.5" />
                          )}
                          AI 帮我想
                        </Button>
                      </div>
                      <CardDescription className="text-xs">
                        想让文章表达的核心立场或结论
                      </CardDescription>
                    </CardHeader>
                    <CardContent className="space-y-3">
                      <Textarea
                        placeholder="例如：香港保险在保障范围和分红方面更有优势，但内地保险在理赔便利性和监管保障方面更胜一筹..."
                        value={coreOpinion}
                        onChange={(e) => setCoreOpinion(e.target.value)}
                        rows={3}
                        className="resize-none text-sm border-slate-200"
                      />
                      
                      {/* AI 建议的观点 */}
                      {suggestedOpinions.length > 0 && (
                        <div className="bg-gradient-to-r from-sky-50 to-cyan-50 rounded-lg p-3 space-y-2 border border-sky-100">
                          <div className="flex items-center gap-1.5 text-xs font-medium text-sky-700">
                            <Sparkles className="w-3.5 h-3.5" />
                            AI 建议的核心观点
                          </div>
                          {suggestedOpinions.map((opinion, index) => (
                            <button
                              key={index}
                              onClick={() => handleSelectOpinion(opinion)}
                              className="w-full text-left p-2.5 bg-white rounded-lg hover:bg-sky-50 transition-all text-xs leading-relaxed border border-sky-100 hover:border-sky-200"
                            >
                              {opinion}
                            </button>
                          ))}
                        </div>
                      )}
                    </CardContent>
                  </Card>

                  {/* 情感基调 */}
                  <Card className="border border-slate-200 shadow-sm">
                    <CardHeader className="pb-3">
                      <CardTitle className="text-base flex items-center gap-2">
                        <Palette className="w-4 h-4 text-sky-500" />
                        情感基调
                      </CardTitle>
                      <CardDescription className="text-xs">
                        影响文章的语气和风格
                      </CardDescription>
                    </CardHeader>
                    <CardContent className="space-y-2">
                      {EMOTION_OPTIONS.map((option) => {
                        const Icon = option.icon;
                        return (
                          <button
                            key={option.value}
                            onClick={() => setEmotionTone(option.value)}
                            className={`w-full text-left p-3 rounded-lg border-2 transition-all ${
                              emotionTone === option.value
                                ? `${option.border} ${option.bg} shadow-sm`
                                : 'border-slate-100 hover:border-slate-200 hover:bg-slate-50'
                            }`}
                          >
                            <div className="flex items-start gap-2">
                              <div className={`w-8 h-8 rounded-lg bg-gradient-to-br ${option.color} flex items-center justify-center flex-shrink-0`}>
                                <Icon className="w-4 h-4 text-white" />
                              </div>
                              <div className="flex-1 min-w-0">
                                <p className={`font-medium text-sm ${emotionTone === option.value ? option.text : 'text-slate-700'}`}>
                                  {option.label}
                                </p>
                                <p className="text-xs text-slate-500 mt-0.5 line-clamp-2">
                                  {option.desc}
                                </p>
                              </div>
                            </div>
                          </button>
                        );
                      })}
                    </CardContent>
                  </Card>
                </div>

                {/* 素材关联 */}
                <Card className="border border-slate-200 shadow-sm">
                  <CardHeader className="pb-3">
                    <div className="flex items-center justify-between">
                      <CardTitle className="text-base flex items-center gap-2">
                        <Paperclip className="w-4 h-4 text-sky-500" />
                        关联素材
                      </CardTitle>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={handleMaterialRecommend}
                        disabled={!mainInstruction.trim() || loadingMaterials}
                        className="h-8 gap-1 text-sky-600 hover:text-sky-700 hover:bg-sky-50"
                      >
                        {loadingMaterials ? (
                          <Loader2 className="w-3.5 h-3.5 animate-spin" />
                        ) : (
                          <Sparkles className="w-3.5 h-3.5" />
                        )}
                        AI 推荐素材
                      </Button>
                    </div>
                    <CardDescription className="text-xs">
                      选择可引用的案例、数据或故事
                    </CardDescription>
                  </CardHeader>
                  <CardContent className="space-y-4">
                    {/* AI 推荐的素材 */}
                    {recommendedMaterials.length > 0 && (
                      <div className="bg-gradient-to-r from-emerald-50 to-teal-50 rounded-lg p-3 space-y-2 border border-emerald-100">
                        <div className="flex items-center gap-1.5 text-xs font-medium text-emerald-700">
                          <Sparkles className="w-3.5 h-3.5" />
                          AI 推荐的素材
                        </div>
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
                          {recommendedMaterials.map((material) => (
                            <button
                              key={material.id}
                              onClick={() => toggleMaterial(material.id)}
                              className={`p-2.5 rounded-lg border text-left transition-all ${
                                selectedMaterialIds.includes(material.id)
                                  ? 'border-emerald-500 bg-emerald-50'
                                  : 'border-slate-200 bg-white hover:bg-slate-50'
                              }`}
                            >
                              <div className="flex items-center gap-2">
                                <span className="text-lg">{getMaterialTypeIcon(material.type)}</span>
                                <span className="font-medium text-xs truncate flex-1">{material.title}</span>
                                {selectedMaterialIds.includes(material.id) && (
                                  <CheckCircle2 className="w-4 h-4 text-emerald-600 flex-shrink-0" />
                                )}
                              </div>
                            </button>
                          ))}
                        </div>
                      </div>
                    )}

                    {/* 素材库列表 */}
                    <div className="space-y-3">
                      <div className="flex gap-2">
                        <Input
                          placeholder="搜索素材..."
                          value={materialSearch}
                          onChange={(e) => setMaterialSearch(e.target.value)}
                          className="h-9 text-sm"
                        />
                        <select
                          value={materialFilter}
                          onChange={(e) => setMaterialFilter(e.target.value)}
                          className="h-9 px-3 border rounded-lg text-sm bg-white"
                        >
                          <option value="all">全部类型</option>
                          <option value="case">案例</option>
                          <option value="data">数据</option>
                          <option value="story">故事</option>
                          <option value="quote">引用</option>
                          <option value="opening">开头</option>
                          <option value="ending">结尾</option>
                        </select>
                      </div>
                      
                      <ScrollArea className="h-40 rounded-lg border border-slate-200">
                        <div className="p-2 space-y-1">
                          {loadingMaterialsList ? (
                            <div className="flex items-center justify-center py-8">
                              <Loader2 className="w-5 h-5 animate-spin text-slate-400" />
                            </div>
                          ) : filteredMaterials.length === 0 ? (
                            <div className="text-center py-8 text-slate-500 text-sm">
                              暂无素材
                            </div>
                          ) : (
                            filteredMaterials.map((material) => (
                              <button
                                key={material.id}
                                onClick={() => toggleMaterial(material.id)}
                                className={`w-full text-left p-2.5 rounded-lg border transition-all ${
                                  selectedMaterialIds.includes(material.id)
                                    ? 'border-indigo-500 bg-indigo-50'
                                    : 'border-transparent hover:bg-slate-50'
                                }`}
                              >
                                <div className="flex items-start gap-2">
                                  <span className="text-lg flex-shrink-0">{getMaterialTypeIcon(material.type)}</span>
                                  <div className="flex-1 min-w-0">
                                    <p className="font-medium text-xs truncate">{material.title}</p>
                                    <p className="text-xs text-slate-500 line-clamp-1">{material.content}</p>
                                    <div className="flex flex-wrap gap-1 mt-1">
                                      {(material.topicTags || []).slice(0, 3).map((tag) => (
                                        <span key={tag} className={`px-1.5 py-0.5 rounded text-xs ${getTagColor(tag)}`}>
                                          {tag}
                                        </span>
                                      ))}
                                    </div>
                                  </div>
                                  {selectedMaterialIds.includes(material.id) && (
                                    <CheckCircle2 className="w-4 h-4 text-indigo-600 flex-shrink-0" />
                                  )}
                                </div>
                              </button>
                            ))
                          )}
                        </div>
                      </ScrollArea>
                    </div>

                    {/* 已选素材 */}
                    {selectedMaterialIds.length > 0 && (
                      <div className="flex items-center gap-2 px-3 py-2 bg-slate-100 rounded-lg">
                        <CheckCircle2 className="w-4 h-4 text-sky-600" />
                        <span className="text-sm text-slate-600">已选 {selectedMaterialIds.length} 个素材</span>
                        <button
                          onClick={() => setSelectedMaterialIds([])}
                          className="ml-auto text-xs text-red-600 hover:text-red-700 hover:underline"
                        >
                          清空
                        </button>
                      </div>
                    )}
                  </CardContent>
                </Card>

                {/* 提交区域 */}
                <Card className="border-2 border-sky-100 bg-gradient-to-r from-sky-50 to-cyan-50 shadow-lg">
                  <CardContent className="pt-6 pb-6">
                    <div className="flex flex-col sm:flex-row items-center justify-between gap-4">
                      {/* 完成度 */}
                      <div className="flex-1 w-full sm:w-auto">
                        <div className="flex items-center justify-between mb-2">
                          <span className="text-sm font-medium text-slate-700 flex items-center gap-1.5">
                            <Target className="w-4 h-4" />
                            准备就绪度
                          </span>
                          <span className="text-sm font-bold text-sky-600">{completion}%</span>
                        </div>
                        <Progress value={completion} className="h-2 bg-slate-200" />
                        <p className="text-xs text-slate-500 mt-1">
                          {completion < 30 ? '建议完善创作主题和核心观点' : 
                           completion < 60 ? '可以开始创作了，继续优化会更好' :
                           completion < 90 ? '准备充分，可以提交创作' :
                           '完美！所有配置已就绪'}
                        </p>
                      </div>

                      {/* 提交按钮 */}
                      <div className="flex items-center gap-3">
                        <Link href="/full-home">
                          <Button variant="outline" size="lg" className="h-12">
                            <History className="w-5 h-5 mr-2" />
                            查看任务
                          </Button>
                        </Link>
                        <Button
                          onClick={handleSubmit}
                          disabled={!mainInstruction.trim() || submitting}
                          size="lg"
                          className="h-12 px-8 bg-gradient-to-r from-sky-500 to-cyan-500 hover:from-sky-600 hover:to-cyan-600 shadow-lg hover:shadow-xl transition-all duration-300"
                        >
                          {submitting ? (
                            <>
                              <Loader2 className="w-5 h-5 animate-spin mr-2" />
                              提交中...
                            </>
                          ) : (
                            <>
                              <PlayCircle className="w-5 h-5 mr-2" />
                              启动创作
                            </>
                          )}
                        </Button>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </TabsContent>

              {/* 系统概览标签页 */}
              <TabsContent value="overview" className="space-y-6">
                {/* 系统功能卡片 */}
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {SYSTEM_FEATURES.map((feature, index) => {
                    const Icon = feature.icon;
                    return (
                      <Card key={index} className="border border-slate-200 hover:border-slate-300 transition-all duration-300 hover:shadow-md">
                        <CardContent className="pt-6">
                          <div className="flex items-start gap-4">
                            <div className={`w-12 h-12 rounded-xl bg-gradient-to-br ${feature.color} flex items-center justify-center flex-shrink-0 shadow-lg`}>
                              <Icon className="w-6 h-6 text-white" />
                            </div>
                            <div className="flex-1">
                              <h3 className="font-semibold text-slate-900">{feature.title}</h3>
                              <p className="text-sm text-slate-600 mt-1">{feature.description}</p>
                            </div>
                          </div>
                        </CardContent>
                      </Card>
                    );
                  })}
                </div>

                {/* 快速操作 */}
                <Card className="border border-slate-200">
                  <CardHeader>
                    <CardTitle className="text-lg">快速访问</CardTitle>
                    <CardDescription>常用功能入口</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                      <Link href="/full-home">
                        <Button variant="outline" className="w-full h-20 flex-col gap-2">
                          <ListTodo className="w-6 h-6" />
                          <span className="text-xs">任务列表</span>
                        </Button>
                      </Link>
                      <Link href="/materials">
                        <Button variant="outline" className="w-full h-20 flex-col gap-2">
                          <Database className="w-6 h-6" />
                          <span className="text-xs">素材库</span>
                        </Button>
                      </Link>
                      <Link href="/wechat-config">
                        <Button variant="outline" className="w-full h-20 flex-col gap-2">
                          <Settings className="w-6 h-6" />
                          <span className="text-xs">发布配置</span>
                        </Button>
                      </Link>
                      <Link href="/task-timeline">
                        <Button variant="outline" className="w-full h-20 flex-col gap-2">
                          <History className="w-6 h-6" />
                          <span className="text-xs">时间线</span>
                        </Button>
                      </Link>
                    </div>
                  </CardContent>
                </Card>

                {/* 回到创作按钮 */}
                <div className="flex justify-center">
                  <Button 
                    size="lg" 
                    onClick={() => setActiveTab('create')}
                    className="h-12 px-8 bg-gradient-to-r from-sky-500 to-cyan-500 hover:from-sky-600 hover:to-cyan-600"
                  >
                    <Sparkles className="w-5 h-5 mr-2" />
                    开始创作
                  </Button>
                </div>
              </TabsContent>
            </Tabs>
          </div>

          {/* 右侧：状态和信息面板 */}
          <div className="space-y-6">
            {/* 工作流程预览 */}
            <Card className="border border-slate-200 shadow-sm">
              <CardHeader className="pb-3">
                <CardTitle className="text-base flex items-center gap-2">
                  <Workflow className="w-4 h-4 text-sky-500" />
                  工作流程
                </CardTitle>
                <CardDescription className="text-xs">
                  创作任务的完整执行流程
                </CardDescription>
              </CardHeader>
              <CardContent>
                <div className="space-y-3">
                  {[
                    { step: 1, title: '任务拆解', desc: 'Agent B 将任务拆解为子任务', active: true },
                    { step: 2, title: '内容创作', desc: 'insurance-d 执行创作任务', active: false },
                    { step: 3, title: '合规校验', desc: 'Agent B 自动合规检查', active: false },
                    { step: 4, title: '内容优化', desc: 'insurance-c 优化完善', active: false },
                    { step: 5, title: '发布准备', desc: '配置并准备发布', active: false }
                  ].map((item, index) => (
                    <div key={item.step} className="flex items-start gap-3">
                      <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold ${
                        index === 0 
                          ? 'bg-gradient-to-br from-sky-500 to-cyan-500 text-white' 
                          : 'bg-slate-100 text-slate-500'
                      }`}>
                        {item.step}
                      </div>
                      <div className="flex-1 pt-1">
                        <p className={`font-medium text-sm ${index === 0 ? 'text-sky-700' : 'text-slate-700'}`}>
                          {item.title}
                        </p>
                        <p className="text-xs text-slate-500 mt-0.5">{item.desc}</p>
                        {index < 4 && (
                          <div className="w-0.5 h-4 bg-slate-200 ml-3.5 mt-2" />
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          </div>
        </div>
      </main>
    </div>
  );
}
