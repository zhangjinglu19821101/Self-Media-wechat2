/**
 * 获取 Agent 提示词
 */
export function getAgentPrompt(agentId: AgentId): string {
  return AGENT_PROMPTS[agentId].systemPrompt;
}

/**
 * 获取 Agent 行为规则
 */
export function getAgentBehaviorRules(agentId: AgentId): string[] {
  return AGENT_PROMPTS[agentId].behaviorRules;
}

/**
 * 获取 Agent 限制
 */
export function getAgentRestrictions(agentId: AgentId): string[] {
  return AGENT_PROMPTS[agentId].restrictions;
}

/**
 * 获取 Agent 技能提示词
 */
export function getAgentSkillPrompts(agentId: AgentId): Record<string, string> {
  return AGENT_PROMPTS[agentId].skillPrompts || {};
}

/**
 * 更新 Agent 提示词
 * （后期可以通过 API 或前端界面调用此函数来修改提示词）
 */
export function updateAgentPrompt(
  agentId: AgentId,
  updates: {
    systemPrompt?: string;
    behaviorRules?: string[];
    restrictions?: string[];
    skillPrompts?: Record<string, string>;
  }
): void {
  if (updates.systemPrompt) {
    AGENT_PROMPTS[agentId].systemPrompt = updates.systemPrompt;
  }
  if (updates.behaviorRules) {
    AGENT_PROMPTS[agentId].behaviorRules = updates.behaviorRules;
  }
  if (updates.restrictions) {
    AGENT_PROMPTS[agentId].restrictions = updates.restrictions;
  }
  if (updates.skillPrompts) {
    AGENT_PROMPTS[agentId].skillPrompts = updates.skillPrompts;
  }
}
