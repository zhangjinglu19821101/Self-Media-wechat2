# ============================================
# 生产环境配置模板 (.env.production.template)
# 复制此文件为 .env.production，填入真实值
# 不要提交到 Git！
# ============================================

# ============================================
# 数据库配置 - 生产数据库
# ============================================
DATABASE_URL="postgresql://用户名:密码@生产数据库地址:5432/生产数据库名?sslmode=require"
PGDATABASE_URL="postgresql://用户名:密码@生产数据库地址:5432/生产数据库名?sslmode=require"

# ============================================
# NextAuth 配置 - 生产环境
# ============================================
# 必须替换为真实域名！
AUTH_SECRET="替换为你的真实密钥-至少32字节"
NEXTAUTH_SECRET="替换为你的真实密钥-至少32字节"
NEXTAUTH_URL="https://你的生产域名.com"

# ============================================
# 应用配置
# ============================================
NODE_ENV="production"
COZE_PROJECT_ENV="PROD"
PORT=5000

# ============================================
# 加密密钥 - 生产必须重新生成
# ============================================
# 生成命令: openssl rand -hex 32
COZE_ENCRYPTION_KEY="替换为你的真实密钥-32字节hex"

# ============================================
# 微信配置
# ============================================
WECHAT_MINI_APPID="你的小程序AppID"
WECHAT_MINI_SECRET="你的小程序AppSecret"
WECHAT_OFFICIAL_ACCOUNTS_JSON='{"agent_d_accounts":[],"agent_insurance_d_accounts":[]}'

# ============================================
# 生产环境不要开启调试
# ============================================
DEBUG="false"
LOG_LEVEL="error"
